# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public deploy URL — injected into canonical, Open Graph, and Twitter meta at build time.
# Production: https://carbonwisecoach.netlify.app
APP_URL="https://carbonwisecoach.netlify.app"
